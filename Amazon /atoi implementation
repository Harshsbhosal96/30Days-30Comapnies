#include<bits/stdc++.h>

class solution{

public:

      int atoi(string s){
int i = 0, sign = 1;
long long num = 0;

while(i < s.size() && s[i] == ' ') i++;

//signedness checking

if(s[i] == '-'){
sign = -1;
i++;
}
else if(s[i] == '+') i++;

//conversion

while(i < s.size() && isdigit(s[i])){
num = num * 10 + (s[i] -'0');

if(sign*num > INT_MAX) return INT_MAX;
if(sign*num < INT_MIN) return INT_MIN;
i++;
}
return sign*num;
}
};

